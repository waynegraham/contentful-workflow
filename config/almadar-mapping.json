{
  "version": 1,
  "spaceId": "t7x0vaz0zty0",
  "environmentId": "master",
  "contentTypeId": "alMadarCsv",
  "idempotency": {
    "uniqueFieldId": "iabCode",
    "sourceColumn": "IAB Code",
    "mode": "insert_missing_only"
  },
  "locales": {
    "default": "en-US",
    "target": "ar"
  },
  "options": {
    "deferNonText": true,
    "draftOnly": true,
    "dryRun": true,
    "translateMissingArabic": false,
    "normalizeNA": true
  },
  "requiredFieldPolicy": {
    "logMissingRequired": true,
    "requiredFieldIds": ["iabCode", "title", "description", "section"],
    "skipRowIfMissing": true
  },
  "fieldMappings": [
    {
      "fieldId": "iabCode",
      "type": "Symbol",
      "localized": false,
      "source": { "en-US": "IAB Code" }
    },
    {
      "fieldId": "title",
      "type": "Symbol",
      "localized": true,
      "source": { "en-US": "Title of Object" }
    },
    {
      "fieldId": "origin",
      "type": "Symbol",
      "localized": true,
      "source": { "en-US": "Origin" }
    },
    {
      "fieldId": "hijriDate",
      "type": "Symbol",
      "localized": false,
      "source": { "en-US": "Date" },
      "transform": "parse_hijri_from_date"
    },
    {
      "fieldId": "gregorianDate",
      "type": "Symbol",
      "localized": false,
      "source": { "en-US": "Date" },
      "transform": "parse_gregorian_from_date"
    },
    {
      "fieldId": "material",
      "type": "Array",
      "localized": true,
